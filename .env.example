# Copy to .env.local for local development. Never commit real secrets.
# For Cloudflare Pages: set these in the dashboard (Settings → Environment variables).

# Public URL of your deployed site (used for Stripe redirects and sitemap)
APP_URL=https://your-domain.com

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin area protection (any secret string; users enter it to access /admin)
ADMIN_TOKEN=your-secret-admin-token

# Currency (EUR only)
DEFAULT_CURRENCY=EUR
